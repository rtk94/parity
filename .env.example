# Deployment config for `docker compose`. Copy to `.env` and fill in.
# (This is the compose/production env; backend/.env.example is for local dev.)

# --- required ---
# Generate a long random string, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-string

# --- app (image defaults shown; override only if needed) ---
FLASK_ENV=production
# SQLite lives in the parity-data volume at /data/parity.db by default:
# DATABASE_URL=sqlite:////data/parity.db
WEB_CONCURRENCY=2

# --- reverse proxy (only used with the `edge` profile / Caddy) ---
PARITY_DOMAIN=api.parity.example.com
