FLASK_APP=app:create_app
FLASK_ENV=development
SECRET_KEY=<REPLACE_WITH_RANDOM_STRING>
DATABASE_URL=sqlite:///parity.db

# Push notifications (optional). Path to a Google service-account JSON
# with the Firebase Cloud Messaging API enabled. Leave unset to disable
# push (a no-op sender is used). Each environment points at its own
# project's file, e.g. /etc/parity/fcm-production.json (chmod 600).
# FCM_CREDENTIALS_FILE=

# Outbound email (optional; required for self-service password reset —
# see docs/adr/0002-password-reset-transport.md). Provider-agnostic SMTP:
# point MAIL_SERVER at any relay (SES, Postmark, a self-managed server).
# Leave MAIL_SERVER unset to disable email (a no-op sender is used and
# reset requests deliver nothing).
# MAIL_SERVER=email-smtp.us-east-1.amazonaws.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_USE_TLS=true
# MAIL_FROM=no-reply@parity.rknepp.com
# PASSWORD_RESET_URL_BASE=https://parity.rknepp.com/reset
# PASSWORD_RESET_LIFETIME_MINUTES=60
