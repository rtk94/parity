<?xml version="1.0" encoding="utf-8"?>
<!--
  Auto-backup and device-transfer are disabled at the manifest level
  (allowBackup="false", fullBackupContent="false"). This file exists
  to satisfy android:dataExtractionRules and excludes everything from
  any future backup channel as a defense in depth.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
